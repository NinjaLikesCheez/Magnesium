# fileHeader
--header strip

# use xcode indentation
--xcodeindentation enabled

# numberFormatting
--decimalgrouping 3,5
--fractiongrouping enabled

# unusedArguments
--stripunusedargs closure-only

# wrapArguments
--wraparguments before-first
--wrapcollections before-first

# disabled
--disable specifiers

# version
--swiftversion 5.3
